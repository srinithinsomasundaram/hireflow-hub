# ── Supabase (required) ──────────────────────────────────────────────────────
# Server-side (not exposed to browser)
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE="eyJ..."          # Service role JWT from Supabase dashboard

# Client-side (NEXT_PUBLIC_ prefix required — set in Vercel env vars too)
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."   # Publishable/anon key

# ── Google OAuth (required for Google Sign-In) ────────────────────────────────
GOOGLE_CLIENT_ID="<id>.apps.googleusercontent.com"    # Server-side (token verification)
NEXT_PUBLIC_GOOGLE_CLIENT_ID="<id>.apps.googleusercontent.com"  # Client-side (GIS button)
GOOGLE_CLIENT_SECRET="GOCSPX-..."

# ── Gemini AI (required for pitch generation) ────────────────────────────────
GEMINI_API_KEY="AQ..."

# ── Razorpay (required for payments) ─────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_live_..."
RAZORPAY_KEY_SECRET="..."
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_..."            # Client-side (checkout)

# ── Admin ──────────────────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@example.com"
NEXT_PUBLIC_ADMIN_EMAIL="admin@example.com"           # Client-side (admin check)
