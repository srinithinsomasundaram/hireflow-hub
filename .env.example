# Copy this file to .env.local and fill in real values — never commit .env or .env.local

# Supabase
SUPABASE_URL="https://<project>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
VITE_SUPABASE_URL="https://<project>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# OpenAI
OPENAI_API_KEY="sk-..."

# System email (Resend or SMTP)
RESEND_API_KEY="re_..."
RESEND_FROM="HireFlow <onboarding@yourdomain.com>"
SYSTEM_SMTP_HOST="smtp.resend.com"
SYSTEM_SMTP_PORT="465"
SYSTEM_SMTP_USER="resend"
SYSTEM_SMTP_PASS="re_..."
SYSTEM_EMAIL_FROM="HireFlow <hireflow@yourdomain.com>"
SYSTEM_EMAIL_FROM_NAME="HireFlow"

# Set to "true" when deployed behind a trusted proxy (Cloudflare, Vercel, etc.)
# that controls the X-Forwarded-For header. Enables IP-based rate limiting.
# Leave unset or "false" in development.
TRUSTED_PROXY="true"

# SMTP password encryption key — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes). Rotate by re-encrypting all stored SMTP passwords.
SMTP_ENCRYPTION_KEY="<64-hex-chars>"

# App URL (used in notification emails)
APP_URL="https://app.yourdomain.com"

# Root app domain — used to distinguish tenant subdomains from the app itself.
# e.g. "hireflow.yesp.space" → nexora.hireflow.yesp.space is a tenant,
# but hireflow.yesp.space itself is the main app (no subdomain rewrite).
VITE_APP_DOMAIN="hireflow.yesp.space"
